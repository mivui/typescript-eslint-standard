{
  "name": "typescript-eslint-standard",
  "version": "10.0.2",
  "description": "quickly start eslint in typescript",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.11",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.0",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "author": "mivui",
  "license": "MIT",
  "keywords": [
    "eslint",
    "prettier",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivui/typescript-eslint-standard.git"
  },
  "bugs": {
    "url": "https://github.com/mivui/typescript-eslint-standard/issues"
  },
  "homepage": "https://github.com/mivui/typescript-eslint-standard#readme"
}
